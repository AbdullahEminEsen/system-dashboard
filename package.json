{
  "name": "system-dashboard",
  "version": "1.1.6",
  "description": "Gerçek zamanlı sistem bilgilerini gösteren masaüstü widget",
  "author": {
    "name": "Abdullah Emin Esen",
    "email": "esenabdullahemin@gmail.com"
  },
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.systemdashboard.app",
    "productName": "System Dashboard",
    "forceCodeSigning": false,
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "sign": null
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "src/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.2.0",
    "systeminformation": "^5.21.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}